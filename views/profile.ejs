<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Profile Page</title>
    <style>
        :root {
            --bg: #0f172a;
            --card-bg: #1e293b;
            --accent: #38bdf8;
            --accent-hover: #0ea5e9;
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --border: #334155;
            --btn-secondary: #334155;
        }

        body {
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            background-color: var(--bg);
            margin: 0;
            padding: 0;
            color: var(--text-main);
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }

        .container {
            width: 100%;
            max-width: 500px;
            margin: 20px;
            padding: 3rem 2rem;
            background-color: var(--card-bg);
            border-radius: 20px;
            border: 1px solid var(--border);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            text-align: center;
        }

        h2 {
            margin-bottom: 1.5rem;
            font-size: 1.8rem;
            font-weight: 700;
            letter-spacing: -0.025em;
            color: var(--text-main);
        }

        .profile-info {
            margin-bottom: 2rem;
        }

        /* Standard buttons if you add them later */
        button {
            padding: 0.8rem 1.5rem;
            margin: 10px;
            background-color: var(--accent);
            color: #0f172a;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            font-size: 1rem;
            font-weight: 600;
            transition: all 0.2s ease;
        }

        button:hover {
            background-color: var(--accent-hover);
            transform: translateY(-1px);
        }

        .offline-message {
            font-size: 1.1rem;
            margin-bottom: 2rem;
            color: var(--text-muted);
        }

        .links {
            display: flex;
            flex-direction: column;
            gap: 12px;
            margin-top: 1.5rem;
        }

        .links a {
            display: block;
            padding: 0.8rem 1.5rem;
            background-color: var(--btn-secondary);
            color: var(--text-main);
            text-decoration: none;
            border-radius: 10px;
            font-weight: 500;
            border: 1px solid var(--border);
            transition: all 0.2s ease;
        }

        .links a:hover {
            background-color: #475569;
            border-color: var(--text-muted);
            transform: translateY(-1px);
        }

        /* Make the first link (usually Login) pop more */
        .links a:first-child {
            background-color: var(--accent);
            color: #0f172a;
            border: none;
        }
        
        .links a:first-child:hover {
            background-color: var(--accent-hover);
        }

        #not-logged-in p {
            margin-bottom: 1.5rem;
            font-weight: 500;
        }
    </style>
</head>

<body>

    <div class="container">
        <div id="profile-section">
            <div class="offline-message" id="not-logged-in">
                <h2>Profil</h2>
                <p>You are not logged in.</p>
                <div class="links">
                    <a href="login">Log In</a>
                    <a href="register">Register</a>
                </div>
            </div>
        </div>
    </div>

</body>

</html>