<!DOCTYPE html>
<html lang="no">

<head>
  <meta charset="UTF-8" />
  <title>Todo-notater</title>

  <style>
    :root {
      --bg: #0f172a;
      --card-bg: #1e293b;
      --accent: #38bdf8;
      --accent-hover: #0ea5e9;
      --text-main: #f8fafc;
      --text-muted: #94a3b8;
      --border: #334155;
      --input-bg: #0f172a;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
      font-family: 'Inter', system-ui, sans-serif;
    }

    body {
      background: var(--bg);
      color: var(--text-main);
    }

    .topbar {
      display: flex;
      justify-content: space-between;
      padding: 1rem 2rem;
      background: rgba(30, 41, 59, 0.8);
      border-bottom: 1px solid var(--border);
    }

    .container {
      max-width: 650px;
      margin: 2rem auto;
      padding: 0 1.5rem;
    }

    .card {
      background: var(--card-bg);
      padding: 1.5rem;
      margin-bottom: 2rem;
      border-radius: 16px;
      border: 1px solid var(--border);
    }

    input, select {
      width: 100%;
      padding: 0.7rem;
      margin: 0.5rem 0;
      border-radius: 8px;
      border: 1px solid var(--border);
      background: var(--input-bg);
      color: white;
    }

    button {
      padding: 0.7rem 1rem;
      background: var(--accent);
      border: none;
      border-radius: 8px;
      cursor: pointer;
    }

    .row {
      display: flex;
      gap: 10px;
    }

    .todo {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 0.5rem;
    }

    .completed span {
      text-decoration: line-through;
      opacity: 0.6;
    }

    .quick-buttons {
      display: flex;
      gap: 10px;
    }

    .outline {
      background: transparent;
      border: 1px solid var(--accent);
      color: var(--accent);
    }
  </style>
</head>

