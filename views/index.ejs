<!DOCTYPE html>
<html lang="no">
<head>
    <meta charset="UTF-8" />
    <title>Focus Todo</title>
    <style>
        :root {
            --bg: #0f172a;
            --sidebar: #1e293b;
            --accent: #38bdf8;
            --accent-glow: rgba(56, 189, 248, 0.2);
            --text: #f1f5f9;
            --muted: #94a3b8;
            --border: rgba(255, 255, 255, 0.1);
            --card-bg: rgba(30, 41, 59, 0.7);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Inter', system-ui, sans-serif; }

        body {
            background-color: var(--bg);
            color: var(--text);
            display: grid;
            grid-template-columns: 280px 1fr;
            grid-template-rows: 70px 1fr;
            height: 100vh;
            overflow: hidden;
        }

        /* Topbar */
        .topbar {
            grid-column: 1 / -1;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 2rem;
            background: var(--sidebar);
            border-bottom: 1px solid var(--border);
            z-index: 10;
        }

        .profile-link {
            border: 1px solid var(--accent);
            color: var(--accent);
            padding: 0.5rem 1.2rem;
            border-radius: 12px;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.9rem;
            transition: 0.3s;
        }

        .profile-link:hover {
            background: var(--accent-glow);
        }

        /* Sidebar */
        .sidebar {
            background: var(--sidebar);
            padding: 2rem;
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            gap: 2rem;
        }

        /* Main Content */
        .main-content {
            padding: 2rem;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .view-card {
            background: var(--card-bg);
            backdrop-filter: blur(12px);
            width: 100%;
            max-width: 800px;
            padding: 2.5rem;
            border-radius: 24px;
            border: 1px solid var(--border);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            margin-bottom: 2rem;
        }

        h3 { margin-bottom: 1.5rem; font-size: 1.5rem; color: var(--accent); }

        /* Form Elements */
        input, select, textarea {
            width: 100%;
            padding: 1rem;
            margin: 0.8rem 0;
            border-radius: 12px;
            border: 1px solid var(--border);
            background: #0f172a;
            color: white;
            font-size: 1rem;
        }

        input:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-glow); }

        button {
            background: var(--accent);
            color: #020617;
            border: none;
            padding: 1rem;
            border-radius: 12px;
            cursor: pointer;
            font-weight: 700;
            transition: transform 0.1s;
        }

        button:active { transform: scale(0.98); }

        /* Items */
        .todo, .note-item {
            padding: 1.2rem;
            border: 1px solid var(--border);
            margin-bottom: 1rem;
            border-radius: 16px;
            background: rgba(255, 255, 255, 0.03);
            transition: 0.2s;
        }

        .todo:hover { border-color: var(--accent); }
        .todo.completed { opacity: 0.5; }
        .todo.completed span { text-decoration: line-through; }

        .smallbtn {
            background: transparent;
            border: 1px solid var(--accent);
            color: var(--accent);
            padding: 6px 12px;
            font-size: 12px;
            width: auto;
            text-decoration: none;
            border-radius: 8px;
            display: inline-block;
        }
    </style>
</head>
<body>

<header class="topbar">
    <h1>Todo-notater</h1>
    <a href="/users/profile" class="profile-link">👤 <%= username.toUpperCase() %></a>
</header>

<aside class="sidebar">
    <div>
        <h3>📂 Lister</h3>
        <form method="GET" action="/">
            <select name="select_list" onchange="this.form.submit()">
                <% if (lists.length === 0) { %>
                    <option>Ingen lister</option>
                <% } else { %>
                    <% lists.forEach(list => { %>
                        <option value="<%= list.id %>" <%= String(list.id) == String(selectedListId) ? "selected" : "" %>>
                            <%= list.title %>
                        </option>
                    <% }) %>
                <% } %>
            </select>
        </form>
    </div>
    
    <div style="margin-top: auto;">
        <h3>✨ Ny Liste</h3>
        <form method="POST" action="/">
            <input type="text" name="createList" placeholder="Navn..." required />
            <button type="submit" style="width: 100%;">Opprett</button>
        </form>
    </div>
</aside>

<main class="main-content">
    <div class="view-card">
        <h3>✅ Oppgaver</h3>
        <div class="scroll-area">
            <% tasks.forEach(task => { %>
                <div class="todo <%= task.is_completed ? 'completed' : '' %>">
                    <div style="display:flex; justify-content:space-between; align-items:center;">
                        <span><%= task.task_content %></span>
                        <div style="display: flex; gap: 8px; align-items: center;">
                            <a href="/tasks/edit/<%= task.id %>" class="smallbtn">Rediger</a>
                            <form method="POST" action="/tasks/toggle">
                                <input type="hidden" name="task_id" value="<%= task.id %>">
                                <input type="hidden" name="is_completed" value="<%= task.is_completed ? 0 : 1 %>">
                                <input type="hidden" name="select_list" value="<%= selectedListId %>">
                                <button type="submit" class="smallbtn"><%= task.is_completed ? "Undo" : "Done" %></button>
                            </form>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
        <form method="POST" action="/" style="margin-top: 1.5rem; display: flex; gap: 10px;">
            <input type="hidden" name="select_list" value="<%= selectedListId %>">
            <input type="text" name="taskcontent" placeholder="Hva må gjøres?" required style="margin:0;">
            <button type="submit" style="width: 120px;">Legg til</button>
        </form>
    </div>

<div class="view-card">
    <h3>📝 Notater</h3>
    <div class="scroll-area">
        <% notes.forEach(note => { %>
            <div class="note-item">
                <div style="display:flex; justify-content:space-between; align-items: flex-start;">
                    <div>
                        <strong><%= note.title %></strong>
                        <p style="font-size: 0.9rem; color: var(--muted); margin-top: 8px;"><%= note.content %></p>
                    </div>
                    <div style="display: flex; gap: 8px;">
                        <form method="POST" action="/notes/edit">
                            <input type="hidden" name="note_id" value="<%= note.id %>">
                            <input type="hidden" name="title" value="<%= note.title %>">
                            <input type="hidden" name="content" value="<%= note.content %>">
                            <button type="submit" class="smallbtn">Rediger</button>
                        </form>

                        <form method="POST" action="/notes/delete">
                            <input type="hidden" name="note_id" value="<%= note.id %>">
                            <button class="smallbtn" style="border-color:#ef4444; color:#ef4444;">Slett</button>
                        </form>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
    <form method="POST" action="/">
        <input type="text" name="noteTitle" placeholder="Tittel" required />
        <textarea name="noteContent" placeholder="Skriv noe lurt..." rows="3"></textarea>
        <button type="submit" style="width: 100%;">Lagre Notat</button>
    </form>
</div>
</main>

</body>
</html>