<!DOCTYPE html>
<html lang="no">
<head>
<meta charset="UTF-8" />
<title>Todo-notater</title>
<style>
:root {
  --bg: #020617; --card: #1e293b; --accent: #38bdf8; --text: #f8fafc; --muted: #94a3b8; --border: #334155;
}
* { margin: 0; padding: 0; box-sizing: border-box; font-family: sans-serif; }
body { background: var(--bg); color: var(--text); height: 100vh; display: flex; flex-direction: column; overflow: hidden; }
.topbar { display: flex; justify-content: space-between; align-items: center; padding: 1rem 2.5rem; background: #0f172a; border-bottom: 2px solid var(--accent); flex-shrink: 0; }
.profile-link { background: var(--accent); color: #020617; padding: 0.6rem 1.4rem; border-radius: 50px; text-decoration: none; font-weight: 800; }
.container { display: flex; gap: 2rem; padding: 2rem; overflow-x: auto; flex: 1; align-items: flex-start; }
.card { background: var(--card); padding: 1.8rem; border-radius: 24px; border: 1px solid var(--border); min-width: 400px; max-height: 80vh; display: flex; flex-direction: column; }
.scroll-area { flex: 1; overflow-y: auto; margin-bottom: 1rem; }
h3 { margin-bottom: 1.2rem; color: var(--accent); letter-spacing: 1px; }
input, select, textarea { width: 100%; padding: 0.8rem; margin: 0.5rem 0; border-radius: 12px; border: 1px solid var(--border); background: #0f172a; color: white; }
button { background: var(--accent); color: #020617; border: none; padding: 0.8rem; border-radius: 12px; cursor: pointer; font-weight: 700; width: 100%; }
.smallbtn { background: transparent; border: 1px solid var(--accent); color: var(--accent); padding: 4px 10px; font-size: 11px; width: auto; border-radius: 8px; cursor: pointer; }
.todo, .note-item { padding: 1rem; border: 1px solid var(--border); margin-bottom: 0.8rem; border-radius: 12px; background: rgba(255,255,255,0.02); }
.todo.completed span { text-decoration: line-through; opacity: 0.5; }
summary { font-size: 0.8rem; color: var(--accent); cursor: pointer; margin-top: 10px; list-style: none; }
summary:hover { text-decoration: underline; }
</style>
</head>
<body>

<header class="topbar">
  <h1>Todo-notater</h1>
  <a href="/users/profile" class="profile-link">👤 <%= username.toUpperCase() %></a>
</header>

<div class="container">
  <div class="card">
    <h3>📂 Lister</h3>
    <form method="GET" action="/">
      <select name="select_list" onchange="this.form.submit()">
        <% if (lists.length === 0) { %>
          <option>Ingen lister</option>
        <% } else { %>
          <% lists.forEach(list => { %>
            <option value="<%= list.id %>" <%= String(list.id) == String(selectedListId) ? "selected" : "" %>>
              <%= list.title %>
            </option>
          <% }) %>
        <% } %>
      </select>
    </form>
    <hr style="margin: 1.5rem 0; border: 0; border-top: 1px solid var(--border);">
    <h3>✨ Ny Liste</h3>
    <form method="POST" action="/">
      <input type="text" name="createList" placeholder="Navn på liste..." required />
      <button type="submit">Opprett</button>
    </form>
  </div>

  <div class="card">
    <h3>✅ Oppgaver</h3>
    <div class="scroll-area">
      <% tasks.forEach(task => { %>
        <div class="todo <%= task.is_completed ? 'completed' : '' %>">
          <div style="display:flex; justify-content:space-between; align-items:center;">
            <span><%= task.task_content %></span>
            <form method="POST" action="/tasks/toggle">
              <input type="hidden" name="task_id" value="<%= task.id %>">
              <input type="hidden" name="is_completed" value="<%= task.is_completed ? 0 : 1 %>">
              <input type="hidden" name="select_list" value="<%= selectedListId %>">
              <button type="submit" class="smallbtn"><%= task.is_completed ? "Undo" : "Done" %></button>
            </form>
          </div>
        </div>
      <% }) %>
    </div>
    <form method="POST" action="/">
      <input type="hidden" name="select_list" value="<%= selectedListId %>">
      <input type="text" name="taskcontent" placeholder="Ny oppgave..." required />
      <button type="submit">Legg til</button>
    </form>
  </div>

  <div class="card">
    <h3>📝 Notater</h3>
    <div class="scroll-area">
      <% notes.forEach(note => { %>
        <div class="note-item">
          <div style="display:flex; justify-content:space-between;">
            <strong><%= note.title %></strong>
            <form method="POST" action="/notes/delete">
              <input type="hidden" name="note_id" value="<%= note.id %>">
              <button class="smallbtn" style="border-color:#ef4444; color:#ef4444;">Slett</button>
            </form>
          </div>
          <p style="font-size: 0.85rem; color: var(--muted); margin-top: 5px;"><%= note.content %></p>
          
          <details>
            <summary>Rediger notat</summary>
            <form method="POST" action="/notes/edit" style="margin-top:10px; padding-top:10px; border-top: 1px solid var(--border);">
              <input type="hidden" name="note_id" value="<%= note.id %>">
              <input type="text" name="title" value="<%= note.title %>" placeholder="Tittel">
              <textarea name="content" placeholder="Innhold"><%= note.content %></textarea>
              <button type="submit" class="smallbtn" style="width:100%; margin-top:5px;">Oppdater</button>
            </form>
          </details>
        </div>
      <% }) %>
    </div>
    <form method="POST" action="/">
      <input type="text" name="noteTitle" placeholder="Tittel" required />
      <textarea name="noteContent" placeholder="Innhold..."></textarea>
      <button type="submit">Lagre Notat</button>
    </form>
  </div>
</div>
</body>
</html>